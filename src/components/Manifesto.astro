---
---

<section class="manifesto-section" aria-label="Bondli manifesto">
  <div class="container">
    <div class="manifesto-initial-wrap">
      <img src="/logo.svg" alt="" class="manifesto-initial" aria-hidden="true" />
    </div>
    <blockquote>
      "Built <em>for the people</em> on<br />
      both sides of the wall."
    </blockquote>
    <cite>— The Bondli team</cite>
  </div>
</section>

<style>
  .manifesto-section {
    background: var(--text);
    color: #fff;
    text-align: center;
  }

  .manifesto-initial-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 36px;
  }

  .manifesto-initial {
    height: 120px;
    width: auto;
    display: block;
    border-radius: 28px;
    box-shadow: 0 0 0 8px rgba(232, 160, 32, 0.18);
  }

  .manifesto-section blockquote {
    font-size: clamp(24px, 3.5vw, 42px);
    font-weight: 700;
    line-height: 1.28;
    letter-spacing: -0.025em;
    max-width: 780px;
    margin: 0 auto 28px;
  }

  .manifesto-section blockquote em {
    font-style: normal;
    color: var(--brand);
  }

  .manifesto-section cite {
    display: block;
    font-size: 14px;
    font-style: normal;
    color: rgba(255, 255, 255, 0.4);
    font-weight: 500;
    letter-spacing: 0.04em;
  }
</style>
