---
---

<section class="hero" aria-labelledby="hero-heading">
  <h1 id="hero-heading">
    A <em>smart</em> communications solution for<em><br />justice-impacted people and their families</em>.
  </h1>

  <p class="hero-sub">
    Building Bondli so families can stay connected with their incarcerated loves ones through advanced and reliable
    technology.
  </p>

  <a href="https://c.org/t7krQPzPsx" class="btn btn-primary btn-hero"
    aria-label="Support the mission — opens tab with petition to sign">
    Support the mission
    <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
      stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
      focusable="false">
      <path d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </a>

  <p class="cta-note">Goal: 1,000 signatures</p>
</section>

<style>
  .hero {
    padding: 148px 24px 96px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero h1 {
    font-size: clamp(44px, 6.5vw, 76px);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.035em;
    color: var(--text);
    max-width: 820px;
    margin-bottom: 24px;
  }

  .hero h1 em {
    font-style: normal;
    color: var(--brand);
  }

  .hero-sub {
    font-size: clamp(17px, 2vw, 20px);
    font-weight: 400;
    line-height: 1.65;
    color: var(--text-sec);
    max-width: 520px;
    margin-bottom: 44px;
  }

  .cta-note {
    margin-top: 20px;
    font-size: 14px;
    color: var(--text-muted);
  }
</style>
