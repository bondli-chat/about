---
import PhoneShowcase from './PhoneShowcase.astro';

const rows = [
  {
    layout: 'default',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
    heading: 'Lower costs',
    body: "Familiar messaging technology that won't break families' wallets.",
    label: 'Messaging screenshots',
    screens: [
      { src: 'screens/screen1.png', alt: 'Messages inbox' },
      { src: 'screens/screen4.png', alt: 'Live chat conversation' },
      { src: 'screens/screen2.png', alt: 'Contacts list' },
      { src: 'screens/screen3.png', alt: 'Connection requests' },
    ],
  },
  {
    layout: 'flip right',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    heading: 'Reliable & transparent',
    body: "Won't go down when you need it the most. Built for the moments that can't wait.",
    label: 'Reliable messaging screenshots',
    screens: [
      { src: 'screens/screen7.png', alt: 'Message delivery in chat' },
      { src: 'screens/screen8.png', alt: 'Flagged messages list' },
    ],
  },
  {
    layout: 'default',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" focusable="false"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`,
    heading: 'AI-moderated',
    body: 'Fast, efficient, and unbiased moderation with a privacy-first mindset.',
    label: 'Moderation screenshots',
    screens: [
      { src: 'screens/screen5.png', alt: 'AI moderation queue' },
      { src: 'screens/screen6.png', alt: 'Message review with AI assessment' },
    ],
  },
];
---

<section class="features-section" id="features" aria-labelledby="features-heading">
  <div class="container">
    <p class="section-label" aria-hidden="true">What makes Bondli different</p>
    <h2 class="section-title" id="features-heading">Built for the people...</h2>
    <p class="section-sub">We listened and studied the current pains families are experiencing from the current
      systems in place. At Bondli, features are crafted to solve real needs.</p>

    <div class="feature-rows">
      {rows.map((row) => (
        <div class={`feature-row${row.layout.includes('flip') ? ' feature-row--flip' : ''}${row.layout.includes('right') ? ' feature-row--right' : ''}`}>
          <div class="feature-row-copy">
            <div class="feature-heading">
              <div class="feature-icon" aria-hidden="true">
                <Fragment set:html={row.icon} />
              </div>
              <h3>{row.heading}</h3>
            </div>
            <p>{row.body}</p>
          </div>
          <div class="feature-row-media">
            <PhoneShowcase screens={row.screens} label={row.label} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--bg-warm);
  }

  .feature-rows {
    display: flex;
    flex-direction: column;
    gap: 96px;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 80px;
  }

  .feature-row--flip .feature-row-media {
    order: -1;
  }

  .feature-row--center {
    grid-template-columns: 1fr;
    justify-items: center;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  .feature-row--center .feature-row-copy p {
    max-width: none;
    margin: 0 auto;
  }

  .feature-heading {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 14px;
  }

  .feature-row--center .feature-heading {
    justify-content: center;
  }

  .feature-row--right .feature-row-copy {
    text-align: right;
  }

  .feature-row--right .feature-heading {
    justify-content: flex-end;
  }

  .feature-row--right .feature-row-copy p {
    margin-left: auto;
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    background: var(--brand-light);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--brand);
  }

  .feature-icon :global(svg) {
    width: 22px;
    height: 22px;
  }

  .feature-row-copy h3 {
    font-size: clamp(26px, 3vw, 36px);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.025em;
    margin-bottom: 0;
  }

  .feature-row-copy p {
    font-size: 17px;
    line-height: 1.72;
    color: var(--text-sec);
    max-width: 400px;
  }

  .feature-row-media {
    display: flex;
    justify-content: center;
  }

  @media (max-width: 900px) {
    .feature-row {
      grid-template-columns: 1fr;
      gap: 40px;
      text-align: center;
    }

    .feature-row--right .feature-row-copy {
      text-align: center;
    }

    .feature-row--right .feature-heading {
      justify-content: center;
    }

    .feature-row--right .feature-row-copy p {
      margin-left: 0;
    }

    .feature-heading {
      justify-content: center;
    }

    .feature-row--flip .feature-row-media {
      order: 0;
    }

    .feature-row-copy p {
      max-width: none;
      margin: 0 auto;
    }
  }
</style>
