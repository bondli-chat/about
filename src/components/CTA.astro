<section class="cta-section" aria-labelledby="cta-heading">
  <div class="container">
    <h2 id="cta-heading">Support the mission.</h2>
    <a href="https://c.org/t7krQPzPsx" class="btn btn-primary btn-hero" aria-label="Make a difference">
      Make a difference
      <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
        focusable="false">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</section>

<style>
  .cta-section {
    background: var(--bg-amber);
    text-align: center;
  }

  .cta-section h2 {
    font-size: clamp(32px, 4.5vw, 54px);
    font-weight: 800;
    line-height: 1.12;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .cta-section p {
    font-size: 18px;
    line-height: 1.65;
    color: var(--text-sec);
    max-width: 460px;
    margin: 0 auto 44px;
  }
</style>
