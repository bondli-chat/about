---
---

<nav>
  <img src="/logo.png" alt="Bondli" class="nav-logo" />
  <ul class="nav-links" role="list">
    <li><a href="#features">Features</a></li>
    <li class="has-dropdown">
      <span aria-haspopup="true">
        Research
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
      </span>
      <ul class="nav-dropdown" role="list">
        <div class="nav-dropdown-inner">
          <li><a href="#for-facilities">For Facilities</a></li>
          <li><a href="#for-families">For Families</a></li>
        </div>
      </ul>
    </li>
    <li><a href="https://deck.bondli.chat" target="_blank" rel="noopener noreferrer">For Investors</a></li>
  </ul>
  <div class="nav-actions">
    <a href="mailto:hello@bondli.chat?subject=My%20Story" class="btn btn-ghost-nav"
      aria-label="Share your story — opens email to hello@bondli.chat">
      Share your story
    </a>
    <a href="https://c.org/t7krQPzPsx" class="btn btn-primary" aria-label="Make a difference">
      Make a difference
      <svg class="btn-arrow" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none"
        stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
        focusable="false">
        <path d="M5 12h14M12 5l7 7-7 7" />
      </svg>
    </a>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    inset-inline: 0;
    z-index: 50;
    padding: 0 32px;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    height: 44px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 36px;
    list-style: none;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }

  .nav-links a {
    font-size: 15px;
    font-weight: 500;
    color: var(--text-sec);
    text-decoration: none;
    transition: color var(--ease);
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-links li.has-dropdown {
    position: relative;
  }

  .nav-links li.has-dropdown > span {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 15px;
    font-weight: 500;
    color: var(--text-sec);
    cursor: default;
    transition: color var(--ease);
  }

  .nav-links li.has-dropdown:hover > span,
  .nav-links li.has-dropdown:focus-within > span {
    color: var(--text);
  }

  .nav-links li.has-dropdown > span svg {
    width: 12px;
    height: 12px;
    transition: transform var(--ease);
  }

  .nav-links li.has-dropdown:hover > span svg,
  .nav-links li.has-dropdown:focus-within > span svg {
    transform: rotate(180deg);
  }

  .nav-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    padding-top: 10px;
    z-index: 100;
    min-width: 180px;
    list-style: none;
  }

  .nav-dropdown-inner {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
    padding: 6px;
  }

  .nav-links li.has-dropdown:hover .nav-dropdown,
  .nav-links li.has-dropdown:focus-within .nav-dropdown {
    display: block;
  }

  .nav-dropdown a {
    display: block;
    padding: 9px 14px;
    border-radius: 8px;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-sec);
    text-decoration: none;
    transition: background var(--ease), color var(--ease);
    white-space: nowrap;
  }

  .nav-dropdown a:hover {
    background: var(--bg-amber);
    color: var(--text);
  }

  @media (max-width: 640px) {
    nav {
      padding: 0 20px;
    }

    .nav-links {
      display: none;
    }

    .btn-ghost-nav {
      display: none;
    }
  }
</style>
